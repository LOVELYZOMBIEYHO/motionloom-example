<!-- Paper magnifier typography animation. Uses embedded base64 paper texture and true magnify_lens process effect. -->
<Graph fps={30} duration="6s" size={[1080,1080]} renderSize={[1080,1080]}>
  <Background color="#F6F2E8" />

  <Scene id="paper_magnifier_source_6s">
    <Defs>
      <Texture id="paper_texture" src="data:image/jpeg;base64," kind="image" />
      <Texture id="paper_height" src="data:image/jpeg;base64," kind="height" />
      <RadialGradient id="paper_warmth" cx="0.48" cy="0.44" r="0.92"
                      stops="0:#FFFDF7, 0.42:#F4EBD8, 0.76:#E4D4B8, 1:#BDAA87" />
      <LinearGradient id="paper_fiber_wash" x1="0" y1="0" x2="1" y2="1"
                      stops="0:#FFFFFF42, 0.36:#C9B48A16, 0.72:#856C451C, 1:#FFFFFF12" />
      <RadialGradient id="edge_vignette" cx="0.50" cy="0.48" r="0.82"
                      stops="0:#00000000, 0.72:#00000008, 1:#00000030" />
      <LinearGradient id="subtle_scan" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#00000000, 0.50:#0000000B, 1:#00000000" />
    </Defs>

    <Timeline>
      <Track id="main" space="world" z="0">
        <Sequence from="0s" duration="6s" out="hold">
          <Layer>
            <Rect x="0" y="0" width="1080" height="1080" fill="url(#paper_warmth)" />
            <Rect x="0" y="0" width="1080" height="1080" fill="url(#paper_fiber_wash)" blend="multiply" opacity="0.70" />
            <Rect x="0" y="0" width="1080" height="1080" fill="url(#edge_vignette)" />

            <Repeat id="paper_lines" count="44" x="0" y="60" yStep="22" opacity="0.20" opacityStep="-0.001">
              <Rect x="0" y="0" width="1080" height="2" fill="url(#subtle_scan)" />
            </Repeat>

            <Group id="base_type"
                   opacity={curve("0:0:linear, 0.45:1:ease_out, 5.5:1:linear, 6:0:ease_in")}
                   transformOriginX="540" transformOriginY="522">
              <Text value="Motionloom" x="center" y="522" fontFamily="Arial" fontWeight="900" fontSize="82" renderScale="4x" color="#151515" opacity="0.94" />
              <Text value="Motionloom graphics through a paper lens" x="center" y="594" fontFamily="Arial" fontSize="22" renderScale="4x" color="#55514A" opacity="0.58" />
              <Rect x="175" y="544" width="730" height="3" color="#151515" opacity="0.16" />
            </Group>

            <Group id="annotation" opacity={curve("0:0:linear, 4.65:0:linear, 5.12:1:ease_out, 6:0:ease_in")}> 
              <Text value="Motionloom magnify lens process" x="center" y="890" fontFamily="Arial" fontWeight="700" fontSize="34" renderScale="4x" color="#272019" opacity="0.68" />
            </Group>
          </Layer>
        </Sequence>
      </Track>
    </Timeline>
  </Scene>

  <Process id="paper_magnifier_post">
    <Tex id="src" fmt="rgba16f" from="scene:paper_magnifier_source_6s" />
    <Tex id="paper" fmt="rgba16f" size={[1080,1080]} />
    <Tex id="out" fmt="rgba16f" size={[1080,1080]} />
    <Pass id="post_paper_texture" kind="compute" effect="texture_overlay"
          in={["src"]} out={["paper"]}
          params={{
            kind: "paper",
            texture: "paper_texture",
            height: "paper_height",
            scale: "1.0",
            strength: "0.38",
            contrast: "1.05",
            bump_strength: "0.72",
            relief: "0.55"
          }} />
    <Pass id="lens" kind="compute" effect="magnify_lens"
          in={["paper"]} out={["out"]}
          params={{
            x: "curve(\"0:300:ease_out, 3:650:ease_in_out, 6:560:ease_out\")",
            y: "520",
            radius: "180",
            zoom: "1.85",
            distortion: "0.18",
            feather: "10",
            glass: "0.32"
          }} />
  </Process>

  <Present from="paper_magnifier_post" />
</Graph>
