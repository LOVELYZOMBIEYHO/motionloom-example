  <Process id="lotus_post">
    <Tex id="scene_src" fmt="rgba16f" from="scene:lotus_bloom_meditation_portrait_15s" />
    <Tex id="hsla_src" fmt="rgba16f" size={[1080,1920]} />
    <Tex id="bloom_src" fmt="rgba16f" size={[1080,1920]} />

    <Pass id="post_hsla" kind="compute" effect="hsla_overlay"
          in={["scene_src"]} out={["hsla_src"]}
          params={{
            hue: "curve(\"0:40:linear, 3:35:ease_in_out, 6:30:ease_in, 9:46:ease_in_out, 15:42:ease_in\")",
            saturation: "curve(\"0:0.10:linear, 2:0.25:ease_out, 5:0.30:ease_in_out, 6:0.20:ease_in, 8:0.34:ease_out, 14:0.32:linear, 15:0.12:ease_in\")",
            lightness: "curve(\"0:0.02:linear, 2:0.06:ease_out, 5:0.05:ease_in_out, 6:0.02:ease_in, 8:0.08:ease_out, 14:0.07:linear, 15:0.01:ease_in\")",
            alpha: "curve(\"0:0.15:linear, 2:0.25:ease_out, 5:0.28:linear, 6:0.18:ease_in, 8:0.30:ease_out, 14:0.28:linear, 15:0.08:ease_in\")"
          }} />

    <Pass id="post_bloom" kind="compute" effect="glow_bloom"
          in={["hsla_src"]} out={["bloom_src"]}
          params={{
            threshold: "0.38",
            intensity: "curve(\"0:0.6:linear, 1.5:1.2:ease_out, 4:1.6:ease_in_out, 6:1.0:ease_in, 7.4:2.0:ease_out, 12:1.7:ease_in_out, 15:0.55:ease_in\")",
            sigma: "14.0"
          }} />
  </Process>

  <Present from="lotus_post" />
</Graph>
