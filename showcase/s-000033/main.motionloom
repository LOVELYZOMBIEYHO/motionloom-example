<!-- Portrait six-line RGB glitch typography promo built from fixed text layers and numeric beat cuts. -->
<Graph fps={30} duration="9s" size={[1080,1920]} renderSize={[1080,1920]}>
  <Background color="#000000" />

  <Scene id="six_line_rgb_glitch_typography_portrait_9s">
    <Timeline>
      <Track id="glitch_typography_content" space="world" z="0">
        <Sequence from="0s" duration="9s" out="hold">
          <Layer>
            <Rect x="0" y="0" width="1080" height="1920" color="#000000" />

            <!-- Low-opacity scanlines and deterministic digital debris. -->
            <Group id="screen_texture" opacity="0.18">
              <Repeat id="scanline_field" count="80" x="0" y="0" yStep="24" opacity="0.36" opacityStep="-0.004">
                <Rect x="0" y="0" width="1080" height="1" color="#FFFFFF" opacity="0.10" />
              </Repeat>
              <Repeat id="pixel_noise" count="30" x="34" y="70" xStep="36" yStep="59" opacity="0.40" opacityStep="-0.009">
                <Rect x="random(-16,16,floor($time.sec*5)+41)" y="random(-10,10,floor($time.sec*5)+59)" width="18" height="2" color="#FFFFFF" opacity="0.18" />
              </Repeat>
            </Group>

            <!-- Six 1.5s text hits: s-000033 typography style, with beat-cut motion transitions. -->
            <Group id="six_line_typography_hits" x="0" y="0">
              <Group id="hit_01_afraid"
                     opacity={curve("0:0:linear, 0.00:0:linear, 0.02:1:linear, 1.43:1:linear, 1.46:0:linear, 9:0:linear")}
                     scale={curve("0:0.72:linear, 0.00:0.72:linear, 0.14:1.16:ease_out, 1.22:1.0:ease_in_out, 9:1.0:linear")}
                     rotation={curve("0:-1.8:linear, 0.00:-1.8:linear, 0.14:0:ease_out, 9:0:linear")}
                     transformOriginX="540" transformOriginY="960">
                <Text value="AFRA D?" x="center" y="420" fontFamily="Avenir Next Condensed" fontWeight="800" fontSize="78" textGap="14" color="#151515" opacity="0.84" />
                <Text value="A F R A I D" x="center" y="1470" fontFamily="Avenir Next Condensed" fontWeight="800" fontSize="78" textGap="14" color="#101820" opacity="0.80" />

                <Group id="hit_01_afraid_rgb_stack" x={curve("0.00:-48:ease_out, 0.14:0:ease_out, 1.22:0:linear, 1.46:24:ease_in")}>
                  <Group id="hit_01_afraid_cyan_offset" x="-12">
                    <Text value="Afraid?" x="center" y="900" fontFamily="Avenir Next Condensed" fontWeight="900" fontSize="176" textGap="5" renderScale="4x" color="#00E5FF"
                          opacity={curve("0.00:0:linear, 0.02:0.90:linear, 9:0.70:linear")} />
                  </Group>
                  <Group id="hit_01_afraid_red_offset" x="12">
                    <Text value="Afraid?" x="center" y="900" fontFamily="Avenir Next Condensed" fontWeight="900" fontSize="176" textGap="5" renderScale="4x" color="#FF2A3D"
                          opacity={curve("0.00:0:linear, 0.02:0.86:linear, 9:0.66:linear")} />
                  </Group>
                  <Text value="Afraid?" x="center" y="900" fontFamily="Avenir Next Condensed" fontWeight="900" fontSize="176" textGap="5" renderScale="4x" color="#FFFFFF"
                        opacity={curve("0.00:0:linear, 0.02:1:linear, 9:1:linear")} />
                </Group>

                <Group id="hit_01_afraid_glitch_slices">
                  <Rect x={curve("0.00:80:ease_in_out, 0.14:720:ease_in_out, 1.22:190:ease_in_out")} y="790" width="300" height="18" color="#000000"
                        opacity={curve("0.00:0.92:linear, 0.14:0:ease_in, 1.22:0.82:ease_out, 1.46:0:ease_in")} />
                  <Rect x={curve("0.00:900:ease_in_out, 0.14:250:ease_in_out, 1.22:610:ease_in_out")} y="1006" width="260" height="14" color="#00E5FF"
                        opacity={curve("0.00:0.66:linear, 0.14:0:ease_in, 1.22:0.62:ease_out, 1.46:0:ease_in")} />
                  <Rect x={curve("0.00:240:ease_in_out, 0.14:900:ease_in_out, 1.22:380:ease_in_out")} y="1080" width="320" height="10" color="#FF2A3D"
                        opacity={curve("0.00:0.60:linear, 0.14:0:ease_in, 1.22:0.58:ease_out, 1.46:0:ease_in")} />
                </Group>

                <Repeat id="hit_01_afraid_electric" count="8" x="180" y="782" xStep="104" yStep="46" opacity="0.82" opacityStep="-0.030">
