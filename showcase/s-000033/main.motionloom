                  <Line x1="28" y1="122" x2="110" y2="146" stroke="#FF2A3D" strokeWidth="2" opacity={curve("0.00:0:linear, 0.14:0.58:ease_out, 1.22:0.14:linear, 1.46:0:ease_in")} />
