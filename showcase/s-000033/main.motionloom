                  <Line x1="28" y1="122" x2="110" y2="146" stroke="#FF2A3D" strokeWidth="2" opacity={curve("1.40:0:linear, 1.54:0.58:ease_out, 2.72:0.14:linear, 2.96:0:ease_in")} />
