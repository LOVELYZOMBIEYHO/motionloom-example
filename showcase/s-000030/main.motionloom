                <Circle x={curve("12.40:142:ease_in_out, 13.40:226:ease_in_out")} y="214" radius="15" color="#FF78B7" blend="screen" />
                <Text value="REFINE" x="390" y="130" fontFamily="Avenir Next Condensed" fontWeight="800" fontSize="46" color="#9B7CFF" />
                <Text value="Shape every detail" x="390" y="196" fontFamily="Menlo" fontSize="20" color="#EAFBFF" opacity="0.68" />
              </Group>

              <Group id="portrait_create_card" x="130" y="1180" opacity={curve("12.68:0:linear, 13.24:1:ease_out")}>
                <Rect x="0" y="0" width="820" height="330" radius="42" color="#0A1026" stroke="#FF78B7" strokeWidth="2" opacity="0.94" />
                <Rect x="68" y="60" width="244" height="170" radius="22" fill="#050816" stroke="#FF78B7" strokeWidth="3" />
                <Path d="M 160 96 L 160 190 L 240 143 Z" fill="#EAFBFF" stroke="#63E6FF" strokeWidth="3" />
                <Text value="CREATE" x="390" y="130" fontFamily="Avenir Next Condensed" fontWeight="800" fontSize="46" color="#FF78B7" />
                <Text value="Bring it to life" x="390" y="196" fontFamily="Menlo" fontSize="20" color="#EAFBFF" opacity="0.68" />
              </Group>
            </Group>

            <!-- 15-18s: portrait finale. -->
            <Group id="portrait_finale"
                   y={curve("0:-120:linear, 14.58:-120:linear, 15.04:0:ease_out, 18:0:linear")}
                   scale={curve("0:0.54:linear, 14.58:0.54:linear, 15.04:1:ease_out, 17.72:0.95:ease_in_out, 18:0.95:linear")}
                   transformOriginX="540" transformOriginY="960"
