              <Text value="PRESENT / OUTPUT" x="150" y="850" fontFamily="Menlo" fontSize="23" color="#FF78B7"
                    opacity={curve("5.92:0:linear, 6.84:1:ease_out")} />
              <Group id="portrait_editable_geometry" x="140" y="1120">
                <Circle x="400" y="230" radius={curve("5.74:24:ease_out, 6.74:170:ease_out, 8.48:170:linear")} fill="#05081600" stroke="#63E6FF" strokeWidth="5" opacity="0.84" />
                <Rect x="80" y="430" width={curve("5.94:0:ease_out, 7.08:640:ease_out, 8.48:640:linear")} height="250" radius="32" fill="#05081600" stroke="#9B7CFF" strokeWidth="5" opacity="0.72" />
                <Path id="portrait_editable_path" d="M 76 662 L 724 72" stroke="#FF78B7" strokeWidth="4" fill="#05081600"
                      trimEnd={curve("5.84:0:linear, 6.94:1:ease_out")} opacity="0.64" blend="screen" />
              </Group>
            </Group>

            <!-- 9-12s: the three product qualities read vertically. -->
            <Group id="portrait_quality_stack"
                   y={curve("0:-120:linear, 8.58:-120:linear, 9.04:0:ease_out, 11.02:0:linear, 11.52:-80:ease_in_out, 11.80:-2240:ease_in_out, 18:-2240:linear")}
                   scale={curve("0:1.30:linear, 8.58:1.30:linear, 9.04:1:ease_out, 11.02:1:linear, 11.52:1.04:ease_in_out, 11.80:1.12:ease_in_out, 18:1.12:linear")}
                   transformOriginX="540" transformOriginY="960"
                   opacity={curve("0:0:linear, 8.60:0:linear, 9.04:1:ease_out, 11.48:1:linear, 11.80:0.12:ease_in_out, 11.88:0:ease_in, 18:0:linear")}>
              <Group id="portrait_editable_quality" opacity={curve("8.72:0:linear, 9.34:1:ease_out")}>
