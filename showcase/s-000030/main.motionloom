                    trimStart={curve("14.76:0.5:ease_out, 15.84:0:ease_out")} trimEnd={curve("14.76:0.5:ease_out, 15.84:1:ease_out")} />
              <Text value="Video-as-code for AI agents" x="center" y="790" fontFamily="Avenir Next Condensed" fontWeight="800" fontSize="72" color="#FFFFFF" />
              <Text value="Open-source creative infrastructure" x="center" y="1010" fontFamily="Menlo" fontSize="24" color="#63E6FF" opacity="0.78" />
              <Rect x="300" y="1100" width={curve("14.90:0:ease_out, 15.90:480:ease_out, 18:480:linear")} height="4" color="#9B7CFF" opacity="0.84" blend="screen" />
