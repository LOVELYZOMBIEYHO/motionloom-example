                <Text value="Renderable." x="center" y="1370" fontFamily="Avenir Next Condensed" fontWeight="800" fontSize="104" color="#FF78B7" />
              </Group>
            </Group>

            <!-- 12-15s: describe, refine, and create are stacked for mobile viewing. -->
            <Group id="portrait_ideas_in_motion"
                   y={curve("0:820:linear, 11.58:820:linear, 12.04:0:ease_out, 14.52:0:linear, 14.94:-180:ease_in, 18:-180:linear")}
                   scale={curve("0:0.94:linear, 11.58:0.94:linear, 12.04:1:ease_out, 14.02:1:linear, 14.52:1.10:ease_in_out, 14.78:5.70:ease_in_out, 18:5.70:linear")}
                   transformOriginX="540" transformOriginY="1500"
                   opacity={curve("0:0:linear, 11.60:0:linear, 12.04:1:ease_out, 14.48:1:linear, 14.86:0:ease_in_out, 18:0:linear")}>
              <Text value="Your ideas, instantly in motion" x="center" y="170" fontFamily="Avenir Next Condensed" fontWeight="800" fontSize="76" color="#FFFFFF" />
              <Text value="Describe it. Refine it. Make it yours." x="center" y="280" fontFamily="Menlo" fontSize="23" color="#63E6FF" opacity="0.80" />

              <Group id="portrait_describe_card" x="130" y="400" opacity={curve("11.70:0:linear, 12.18:1:ease_out")}>
                <Rect x="0" y="0" width="820" height="330" radius="42" color="#0A1026" stroke="#63E6FF" strokeWidth="2" opacity="0.94" />
                <Rect x="74" y="74" width="220" height="140" radius="24" fill="#050816" stroke="#63E6FF" strokeWidth="3" />
                <Path d="M 112 214 L 84 252 L 164 214" fill="#050816" stroke="#63E6FF" strokeWidth="3" />
                <Rect x="112" y="112" width={curve("11.80:0:ease_out, 12.42:142:ease_out")} height="8" radius="4" color="#EAFBFF" />
                <Text value="DESCRIBE" x="390" y="130" fontFamily="Avenir Next Condensed" fontWeight="800" fontSize="46" color="#63E6FF" />
                <Text value="Start with your idea" x="390" y="196" fontFamily="Menlo" fontSize="20" color="#EAFBFF" opacity="0.68" />
