<!-- Portrait edition of the neon promotional sequence. -->
<Graph fps={30} duration="19s" size={[1080,1920]} renderSize={[1080,1920]}>
  <Background color="#050816" />

  <Scene id="anica_neon_premium_portrait_19s">
    <Defs>
      <RadialGradient id="cyan_ambient" cx="0.50" cy="0.50" r="0.58"
                      stops="0:#63E6FF66, 0.28:#22C7E833, 0.66:#0B4B7022, 1:#05081600" />
      <RadialGradient id="violet_ambient" cx="0.50" cy="0.50" r="0.62"
                      stops="0:#9B7CFF66, 0.30:#7048E833, 0.70:#3518791F, 1:#05081600" />
      <RadialGradient id="magenta_ambient" cx="0.50" cy="0.50" r="0.60"
                      stops="0:#FF78B755, 0.32:#D946A622, 0.72:#6D174D18, 1:#05081600" />
    </Defs>

    <Timeline>
      <Track id="portrait_promo_content" space="world" z="0">
        <Sequence from="0s" duration="19s" out="hold">
          <Layer>
            <Rect x="0" y="0" width="1080" height="1920" color="#050816" />
            <Circle id="portrait_ambient_cyan"
                    x={curve("0:820:ease_in_out, 9:620:ease_in_out, 18:860:ease_in_out")}
                    y={curve("0:260:ease_in_out, 9:620:ease_in_out, 18:360:ease_in_out")}
                    radius={curve("0:520:ease_in_out, 9:680:ease_in_out, 18:580:ease_in_out")}
                    fill="url(#cyan_ambient)" opacity="0.44" blend="screen" />
            <Circle id="portrait_ambient_violet"
                    x={curve("0:160:ease_in_out, 9:430:ease_in_out, 18:220:ease_in_out")}
                    y={curve("0:1540:ease_in_out, 9:1280:ease_in_out, 18:1500:ease_in_out")}
                    radius={curve("0:500:ease_in_out, 9:660:ease_in_out, 18:560:ease_in_out")}
                    fill="url(#violet_ambient)" opacity="0.40" blend="screen" />
            <Circle id="portrait_ambient_magenta" x="880" y="1740" radius="380" fill="url(#magenta_ambient)" opacity="0.22" blend="screen" />

            <!-- Procedural texture remains subtle and asset-free. -->
            <Group id="portrait_procedural_texture" opacity="0.09">
              <Repeat id="portrait_scanlines" count="65" x="0" y="0" yStep="30">
                <Rect x="0" y="0" width="1080" height="1" color="#EAFBFF" opacity="0.18" />
              </Repeat>
              <Repeat id="portrait_vertical_lines" count="14" x="0" y="0" xStep="80">
                <Rect x="0" y="0" width="1" height="1920" color="#EAFBFF" opacity="0.07" />
              </Repeat>
              <Repeat id="portrait_grain" count="22" x="68" y="76" xStep="47" yStep="79" rotationStep="17" opacity="0.38" opacityStep="-0.008">
                <Rect x="0" y="0" width="3" height="16" color="#EAFBFF" opacity="0.30" />
              </Repeat>
            </Group>

            <!-- 0-3s: portrait product lockup. -->
            <Group id="portrait_intro"
                   scale={curve("0:0.82:ease_out, 0.70:1:ease_out, 2.02:1:linear, 2.52:1.10:ease_in_out, 2.78:5.70:ease_in_out, 18:5.70:linear")}
                   transformOriginX="540" transformOriginY="960"
                   opacity={curve("0:0:linear, 0.28:1:ease_out, 2.48:1:linear, 2.86:0:ease_in_out, 18:0:linear")}>
              <Circle x="540" y="870" radius="360" fill="url(#violet_ambient)" opacity="0.42" blend="screen" />
              <Text value="ANICA" x="center" y="820" fontFamily="Avenir Next Condensed" fontWeight="800" fontSize="224" renderScale="4x" color="#FFFFFF" />
              <Text value="Agentic AI Video Editing" x="center" y="1040" fontFamily="Menlo" fontSize="28" textGap="3" renderScale="4x" color="#63E6FF"
                    opacity={curve("0:0:linear, 0.68:0:linear, 1.08:0.82:ease_out, 2.40:0.82:linear, 2.70:0:ease_in")} />
              <Rect x="300" y="1115" width={curve("0:0:linear, 0.90:0:linear, 1.42:480:ease_out, 2.50:480:linear")} height="3" color="#9B7CFF" opacity="0.78" blend="screen" />
            </Group>

            <!-- 3-6s: words are woven vertically into motion and video. -->
            <Group id="portrait_motionloom_story"
                   x={curve("0:80:linear, 2.60:80:linear, 3.04:0:ease_out, 5.02:0:linear, 5.52:-60:ease_in_out, 5.78:-1420:ease_in_out, 18:-1420:linear")}
                   scale={curve("0:0.56:linear, 2.60:0.56:linear, 3.04:1:ease_out, 5.02:1:linear, 5.52:1.04:ease_in_out, 5.78:1.12:ease_in_out, 18:1.12:linear")}
                   transformOriginX="540" transformOriginY="960"
                   opacity={curve("0:0:linear, 2.62:0:linear, 3.04:1:ease_out, 5.48:1:linear, 5.78:0.12:ease_in_out, 5.86:0:ease_in, 18:0:linear")}>
              <Circle x="540" y="420" radius="430" fill="url(#violet_ambient)" opacity="0.46" blend="screen" />
              <Text value="MotionLoom" x="center" y="350" fontFamily="Avenir Next Condensed" fontWeight="800" fontSize="166" renderScale="4x" color="#C8B8FF" />
              <Text value="Primitive-first visual DSL" x="center" y="515" fontFamily="Menlo" fontSize="25" renderScale="4x" color="#63E6FF" opacity="0.82" />

              <Group id="portrait_vertical_workflow" opacity={curve("2.74:0:linear, 3.34:1:ease_out, 5.48:1:linear")}>
                <!-- One asymmetric spine avoids the previous mirrored body-like silhouette. -->
                <Path id="portrait_workflow_spine_glow" d="M 540 700 C 470 860 610 1010 540 1160 C 470 1310 610 1490 540 1710"
                      stroke="#9B7CFF" strokeWidth="10" lineCap="round" fill="#05081600" opacity="0.28" blend="screen"
