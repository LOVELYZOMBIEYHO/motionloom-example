                <Text value="WORDS" x="220" y="750" fontFamily="Menlo" fontSize="22" textGap="5" color="#63E6FF" />
                <Text value="INPUT" x="220" y="846" fontFamily="Menlo" fontSize="16" textGap="3" color="#EAFBFF" opacity="0.48" />

                <Line x1="540" y1="1200" x2="860" y2="1200" stroke="#9B7CFF" strokeWidth="14" opacity="0.12" blend="screen" />
                <Line x1="540" y1="1200" x2={curve("3.06:540:ease_in_out, 3.82:860:ease_in_out")} y2="1200" stroke="#B9A8FF" strokeWidth="3" opacity="0.84" blend="screen" />
                <Circle x="540" y="1200" radius="48" fill="url(#violet_ambient)" opacity="0.90" blend="screen" />
                <Circle x="540" y="1200" radius="8" color="#EAFBFF" blend="screen" />
                <Text value="MOTION" x="680" y="1150" fontFamily="Menlo" fontSize="22" textGap="5" color="#9B7CFF" />
                <Text value="TRANSFORM" x="680" y="1246" fontFamily="Menlo" fontSize="16" textGap="3" color="#EAFBFF" opacity="0.48" />

                <Line x1="220" y1="1600" x2="540" y2="1600" stroke="#FF78B7" strokeWidth="14" opacity="0.12" blend="screen" />
                <Line x1="220" y1="1600" x2={curve("3.26:220:ease_in_out, 4.06:540:ease_in_out")} y2="1600" stroke="#FF9DCA" strokeWidth="3" opacity="0.84" blend="screen" />
                <Circle x="540" y="1600" radius="44" fill="url(#magenta_ambient)" opacity="0.88" blend="screen" />
                <Circle x="540" y="1600" radius="7" color="#EAFBFF" blend="screen" />
                <Text value="VIDEO" x="220" y="1550" fontFamily="Menlo" fontSize="22" textGap="5" color="#FF78B7" />
                <Text value="OUTPUT" x="220" y="1646" fontFamily="Menlo" fontSize="16" textGap="3" color="#EAFBFF" opacity="0.48" />
              </Group>
            </Group>

            <!-- 6-9s: natural-language instructions construct editable geometry. -->
            <Group id="portrait_instructions"
                   y={curve("0:180:linear, 5.58:180:linear, 6.04:0:ease_out, 8.02:0:linear, 8.52:0:ease_in_out, 8.80:0:ease_in_out, 18:0:linear")}
                   scale={curve("0:0.58:linear, 5.58:0.58:linear, 6.04:1:ease_out, 8.02:1:linear, 8.52:0.92:ease_in_out, 8.80:0.08:ease_in_out, 18:0.08:linear")}
                   transformOriginX="540" transformOriginY="960"
                   opacity={curve("0:0:linear, 5.60:0:linear, 6.04:1:ease_out, 8.48:1:linear, 8.80:0.12:ease_in_out, 8.88:0:ease_in, 18:0:linear")}>
              <Text value="AI writes instructions, not just pixels" x="90" y="250" width="900" fontFamily="Avenir Next Condensed" fontWeight="800" fontSize="84" color="#FFFFFF" />
              <Rect x="90" y="600" width="900" height="350" radius="40" color="#0A1026" stroke="#63E6FF" strokeWidth="2" opacity="0.92" />
