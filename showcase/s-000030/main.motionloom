              <Line x1={curve("5.36:1180:ease_in_out, 5.78:-620:ease_in_out")} y1="780" x2={curve("5.36:1740:ease_in_out, 5.78:-60:ease_in_out")} y2="780" stroke="#63E6FF" strokeWidth="11" opacity="0.38" blend="screen" />
