            <!-- Distinct portrait transitions: depth, horizontal whip, collapse, vertical whip, depth. -->
            <Group id="portrait_depth_transition_01" x="540" y="960" opacity={curve("0:0:linear, 2.02:0:linear, 2.52:0.20:ease_in_out, 2.66:0.82:ease_in_out, 2.86:0:ease_in_out, 18:0:linear")}>
