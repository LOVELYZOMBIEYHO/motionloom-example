                <Path id="portrait_workflow_spine_core" d="M 540 700 C 470 860 610 1010 540 1160 C 470 1310 610 1490 540 1710"
                      stroke="#C8B8FF" strokeWidth="3.5" lineCap="round" fill="#05081600" opacity="0.88" blend="screen"
                      trimEnd={curve("2.74:0:ease_in_out, 4.10:1:ease_in_out")} />

                <!-- Alternating branches make the direction and stage ownership explicit. -->
                <Line x1="220" y1="800" x2="540" y2="800" stroke="#63E6FF" strokeWidth="14" opacity="0.12" blend="screen" />
                <Line x1="220" y1="800" x2={curve("2.86:220:ease_in_out, 3.58:540:ease_in_out")} y2="800" stroke="#9CF1FF" strokeWidth="3" opacity="0.84" blend="screen" />
                <Circle x="540" y="800" radius="44" fill="url(#cyan_ambient)" opacity="0.86" blend="screen" />
