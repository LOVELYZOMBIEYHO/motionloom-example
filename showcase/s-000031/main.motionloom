<!-- Cyber-noir portrait promo derived from the book-inspired composition. -->
<Graph fps={30} duration="19s" size={[1080,1920]} renderSize={[1080,1920]}>
  <Background color="#050816" />

  <Scene id="anica_cyber_book_portrait_19s">
    <Defs>
      <RadialGradient id="parchment_base" cx="0.52" cy="0.46" r="0.92"
                      stops="0:#172A50, 0.38:#0C1835, 0.72:#070C1E, 1:#02040C" />
      <RadialGradient id="warm_patch" cx="0.50" cy="0.50" r="0.72"
                      stops="0:#63E6FF55, 0.44:#4C6FFF2E, 1:#05081600" />
      <RadialGradient id="ink_cloud" cx="0.50" cy="0.50" r="0.72"
                      stops="0:#02040CF2, 0.36:#071127E8, 0.72:#173C685C, 1:#173C6800" />
      <RadialGradient id="burn_hole" cx="0.50" cy="0.50" r="0.70"
                      stops="0:#01030AFF, 0.55:#050B1CEE, 0.82:#31236FA8, 1:#31236F00" />
      <LinearGradient id="title_gold" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#FFFFFF, 0.24:#9CF1FF, 0.58:#7A6CFF, 1:#FF9DCA" />
      <LinearGradient id="faded_gold" x1="0" y1="0" x2="1" y2="1"
                      stops="0:#A9F4FF, 0.56:#8B7CFF, 1:#D94FA8" />
      <LinearGradient id="fold_light" x1="0" y1="0" x2="1" y2="0"
                      stops="0:#00000000, 0.42:#63E6FF22, 0.50:#02040CAA, 0.62:#9B7CFF22, 1:#00000000" />
      <LinearGradient id="gold_sweep" x1="0" y1="0" x2="1" y2="0"
                      stops="0:#FFFFFF00, 0.34:#63E6FF55, 0.50:#FFFFFFDD, 0.66:#9B7CFF66, 1:#FFFFFF00" />
      <LinearGradient id="film_scratch" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#FFFFFF00, 0.32:#63E6FF44, 0.66:#02040C88, 1:#FFFFFF00" />
      <LinearGradient id="turn_shadow" x1="0" y1="0" x2="1" y2="0"
                      stops="0:#00000000, 0.20:#02040CCC, 0.48:#010208F2, 0.74:#6D5DFB44, 1:#00000000" />
      <LinearGradient id="turn_highlight" x1="0" y1="0" x2="1" y2="0"
                      stops="0:#FFFFFF00, 0.44:#63E6FF66, 0.54:#FFFFFFAA, 0.68:#FF78B744, 1:#FFFFFF00" />
    </Defs>

    <Timeline>
      <Track id="cyber_book_content" space="world" z="0">
        <Sequence from="0s" duration="19s" out="hold">
          <Layer>
            <!-- Persistent aged page, fold, scratches, and illustrated edge details. -->
            <Rect x="0" y="0" width="1080" height="1920" fill="url(#parchment_base)" />
            <Rect x="0" y="0" width="1080" height="1920" color="#000000" opacity="0.22" />
            <Circle x="220" y="360" radius="520" fill="url(#warm_patch)" opacity="0.42" />
            <Circle x="900" y="1530" radius="560" fill="url(#warm_patch)" opacity="0.34" />

            <Repeat id="book_dust_field" count="62" x="42" y="40" xStep="17" yStep="31" opacity="0.44" opacityStep="-0.003">
              <Circle x="random(-10,10,floor($time.sec*3)+17)" y="random(-7,7,floor($time.sec*3)+31)" radius="1.8" color="#29466F" opacity="0.22" />
            </Repeat>
            <Repeat id="book_scratch_field" count="9" x="90" y="-40" xStep="128" opacity="0.20" opacityStep="-0.010">
              <Rect x="random(-18,18,floor($time.sec*2)+91)" y="0" width="2.2" height="2020" fill="url(#film_scratch)" opacity="0.28" />
            </Repeat>
            <Rect x="505" y="0" width="82" height="1920" fill="url(#fold_light)" opacity="0.70" />
            <Line x1="538" y1="0" x2="538" y2="1920" stroke="#02040C" strokeWidth="4" opacity="0.42" />
            <Line x1="565" y1="0" x2="565" y2="1920" stroke="#63E6FF" strokeWidth="2" opacity="0.16" />

            <Group id="book_edge_art" opacity="0.48">
              <Path d="M 46 58 L 230 58 M 48 58 L 48 250 M 850 58 L 1032 58 M 1032 58 L 1032 250 M 46 1862 L 230 1862 M 48 1670 L 48 1862 M 850 1862 L 1032 1862 M 1032 1670 L 1032 1862"
                    stroke="#18365F" strokeWidth="7" lineCap="round" fill="#00000000" opacity="0.52" />
              <Path d="M 86 1660 C 136 1588 214 1584 278 1644 C 204 1648 160 1694 146 1774"
                    fill="#00000000" stroke="#18365F" strokeWidth="6" opacity="0.40" />
              <Path d="M 820 180 C 878 108 970 122 1004 206 C 928 180 874 214 842 286"
                    fill="#00000000" stroke="#18365F" strokeWidth="6" opacity="0.38" />
            </Group>

            <!-- 0-3s: cover page. -->
            <Group id="book_cover_anica" x={curve("0:-180:ease_out, 0.86:0:ease_out, 2.52:0:linear, 2.92:-440:ease_in_out, 19:-440:linear")}
                   opacity={curve("0:0.30:linear, 0.62:1:ease_out, 2.52:1:linear, 2.96:0:ease_in, 19:0:linear")}
                   transformOriginX="540" transformOriginY="960">
              <Circle x="540" y="840" radius={curve("0:160:ease_out, 1.60:500:ease_in_out, 3:560:ease_out")} fill="url(#burn_hole)" opacity="0.86" />
              <Circle x="540" y="1140" radius="410" fill="url(#ink_cloud)" opacity="0.46" />
              <Text value="ANICA" x="center" y="790" fontFamily="Times New Roman" fontWeight="700" fontSize="210" renderScale="4x" fill="url(#title_gold)" />
              <Text value="Agentic AI Video Editing" x="center" y="1020" fontFamily="Times New Roman" fontSize="42" renderScale="4x" color="#63E6FF"
                    opacity={curve("0:0:linear, 1.02:0:linear, 1.68:0.90:ease_out, 3:0.90:linear")} />
              <Path d="M 250 1110 C 390 1080 690 1080 830 1110" stroke="#9B7CFF" strokeWidth="4" fill="#00000000" opacity="0.74"
                    trimStart={curve("0.80:0.5:ease_out, 1.72:0:ease_out")} trimEnd={curve("0.80:0.5:ease_out, 1.72:1:ease_out")} />
              <Rect x={curve("0.50:-460:ease_out, 1.72:1180:ease_in_out, 3:1480:linear")} y="560" width="260" height="720" fill="url(#gold_sweep)" opacity="0.42" rotation="-8" blend="screen" />
            </Group>

            <!-- 3-6s: motion language page. -->
            <Group id="book_motionloom" x={curve("0:360:linear, 2.72:360:linear, 3.18:0:ease_in_out, 5.52:0:linear, 5.94:-420:ease_in_out, 19:-420:linear")}
                   opacity={curve("0:0:linear, 2.76:0:linear, 3.20:1:ease_out, 5.52:1:linear, 5.98:0:ease_in, 19:0:linear")}>
              <Circle x="620" y="820" radius={curve("2.78:120:ease_out, 4.20:520:ease_in_out, 6:560:linear")} fill="url(#burn_hole)" opacity="0.84" />
              <Text value="MotionLoom" x="center" y="620" fontFamily="Times New Roman" fontWeight="700" fontSize="156" renderScale="4x" fill="url(#title_gold)" />
              <Text value="Primitive-first visual DSL" x="center" y="800" fontFamily="Menlo" fontSize="25" color="#63E6FF" opacity="0.82" />
              <Path d="M 210 1120 C 390 930 690 1310 870 1120" stroke="#9B7CFF" strokeWidth="8" fill="#00000000" opacity="0.18" />
              <Path d="M 210 1120 C 390 930 690 1310 870 1120" stroke="#9CF1FF" strokeWidth="3" fill="#00000000" opacity="0.84"
                    trimEnd={curve("2.86:0:ease_out, 4.18:1:ease_out")} />
              <Text value="WORDS" x="170" y="1320" fontFamily="Menlo" fontSize="19" textGap="4" color="#4BCFFF" />
              <Text value="MOTION" x="470" y="1420" fontFamily="Menlo" fontSize="19" textGap="4" color="#9B7CFF" />
              <Text value="VIDEO" x="790" y="1320" fontFamily="Menlo" fontSize="19" textGap="4" color="#EAFBFF" />
            </Group>

            <!-- 6-9s: instruction manuscript. -->
            <Group id="book_instructions" x={curve("0:340:linear, 5.72:340:linear, 6.18:0:ease_in_out, 8.52:0:linear, 8.94:-430:ease_in_out, 19:-430:linear")}
                   opacity={curve("0:0:linear, 5.76:0:linear, 6.20:1:ease_out, 8.52:1:linear, 8.98:0:ease_in, 19:0:linear")}>
              <Circle x="500" y="980" radius={curve("5.78:120:ease_out, 7.20:600:ease_in_out, 9:630:linear")} fill="url(#ink_cloud)" opacity="0.82" />
              <Text value="AI writes instructions, not just pixels" x="100" y="430" width="880" fontFamily="Times New Roman" fontWeight="700" fontSize="88" renderScale="4x" fill="url(#title_gold)" />
              <Rect x="110" y="920" width="860" height="460" radius="42" color="#081126" stroke="#6D5DFB" strokeWidth="3" opacity="0.76" />
              <Text value="GRAPH / SCENE / GROUP" x="170" y="1030" fontFamily="Menlo" fontSize="24" color="#EAFBFF" />
              <Text value="CURVE / SCALE / OPACITY" x="170" y="1140" fontFamily="Menlo" fontSize="24" color="#9B7CFF"
                    opacity={curve("5.88:0:linear, 6.74:1:ease_out")} />
              <Text value="PRESENT / OUTPUT" x="170" y="1250" fontFamily="Menlo" fontSize="24" color="#FF78B7"
                    opacity={curve("6.08:0:linear, 7.00:1:ease_out")} />
              <Path d="M 160 1470 C 360 1400 720 1540 920 1450" stroke="#63E6FF" strokeWidth="4" fill="#00000000" opacity="0.60"
                    trimEnd={curve("6.20:0:ease_out, 7.48:1:ease_out")} />
            </Group>

            <!-- 9-12s: product qualities as a vertical illuminated manuscript. -->
            <Group id="book_qualities" x={curve("0:360:linear, 8.72:360:linear, 9.18:0:ease_in_out, 11.52:0:linear, 11.94:-430:ease_in_out, 19:-430:linear")}
                   opacity={curve("0:0:linear, 8.76:0:linear, 9.20:1:ease_out, 11.52:1:linear, 11.98:0:ease_in, 19:0:linear")}>
              <Circle x="540" y="960" radius="660" fill="url(#burn_hole)" opacity="0.80" />
              <Text value="Editable." x="center" y="560" fontFamily="Times New Roman" fontWeight="700" fontSize="126" fill="url(#title_gold)"
                    opacity={curve("8.84:0:linear, 9.42:1:ease_out")} />
              <Path d="M 260 650 L 820 650" stroke="#FF78B7" strokeWidth="3" fill="#00000000" opacity="0.60" />
              <Text value="Deterministic." x="center" y="960" fontFamily="Times New Roman" fontWeight="700" fontSize="112" fill="url(#title_gold)"
                    opacity={curve("9.38:0:linear, 10.06:1:ease_out")} />
              <Path d="M 220 1050 L 860 1050" stroke="#FF78B7" strokeWidth="3" fill="#00000000" opacity="0.60" />
              <Text value="Renderable." x="center" y="1360" fontFamily="Times New Roman" fontWeight="700" fontSize="126" fill="url(#title_gold)"
                    opacity={curve("10.02:0:linear, 10.70:1:ease_out")} />
            </Group>

            <!-- 12-15s: user-friendly creative journey. -->
            <Group id="book_ideas" x={curve("0:340:linear, 11.72:340:linear, 12.18:0:ease_in_out, 14.52:0:linear, 14.94:-430:ease_in_out, 19:-430:linear")}
                   opacity={curve("0:0:linear, 11.76:0:linear, 12.20:1:ease_out, 14.52:1:linear, 14.98:0:ease_in, 19:0:linear")}>
              <Circle x="540" y="900" radius="650" fill="url(#ink_cloud)" opacity="0.78" />
              <Text value="Your ideas, instantly in motion" x="70" y="310" width="940" fontFamily="Times New Roman" fontWeight="700" fontSize="84" renderScale="4x" fill="url(#title_gold)" />
              <Text value="Describe it. Refine it. Make it yours." x="center" y="670" fontFamily="Times New Roman" fontSize="36" color="#63E6FF" opacity="0.86" />
              <Group id="book_three_steps" y="830">
                <Text value="I" x="180" y="0" fontFamily="Times New Roman" fontSize="78" color="#EAFBFF" />
                <Text value="DESCRIBE" x="290" y="0" fontFamily="Times New Roman" fontSize="54" color="#EAFBFF" />
                <Path d="M 180 90 L 900 90" stroke="#6D5DFB" strokeWidth="3" fill="#00000000" />
                <Text value="II" x="180" y="270" fontFamily="Times New Roman" fontSize="78" color="#9B7CFF" />
                <Text value="REFINE" x="290" y="270" fontFamily="Times New Roman" fontSize="54" color="#9B7CFF" />
                <Path d="M 180 360 L 900 360" stroke="#6D5DFB" strokeWidth="3" fill="#00000000" />
                <Text value="III" x="180" y="540" fontFamily="Times New Roman" fontSize="78" color="#FF78B7" />
                <Text value="CREATE" x="290" y="540" fontFamily="Times New Roman" fontSize="54" color="#63E6FF" />
              </Group>
            </Group>

            <!-- 15-19s: open-source closing page and embedded official logo. -->
            <Group id="book_finale" x={curve("0:360:linear, 14.72:360:linear, 15.18:0:ease_in_out, 19:0:linear")}
                   opacity={curve("0:0:linear, 14.76:0:linear, 15.20:1:ease_out, 19:1:linear")}>
              <Circle x="540" y="920" radius="680" fill="url(#burn_hole)" opacity="0.84" />
              <Text value="Video-as-code for AI agents" x="50" y="560" width="980" fontFamily="Times New Roman" fontWeight="700" fontSize="82" renderScale="4x" fill="url(#title_gold)" />
              <Text value="Open-source creative infrastructure" x="center" y="900" fontFamily="Times New Roman" fontSize="34" color="#63E6FF" opacity="0.86" />
              <Path d="M 250 1010 C 400 980 680 980 830 1010" stroke="#9B7CFF" strokeWidth="4" fill="#00000000" opacity="0.72"
                    trimStart={curve("15.18:0.5:ease_out, 16.10:0:ease_out")} trimEnd={curve("15.18:0.5:ease_out, 16.10:1:ease_out")} />
              <Image id="book_anica_logo" src="data:image/png;base64," x="100" y="1030" scale="1.10"
                     opacity={curve("0:0:linear, 15.70:0:linear, 16.40:1:ease_in_out, 19:1:linear")} />
            </Group>

            <!-- Five animated page turns separate the six pages. -->
            <Group id="page_turn_01" opacity={curve("0:0:linear, 2.48:0:linear, 2.64:0.92:ease_out, 3.18:0:ease_in, 19:0:linear")}>
              <Rect x={curve("2.48:1120:ease_out, 2.82:430:ease_in_out, 3.18:-360:ease_in_out")} y="-40" width="380" height="2000" fill="url(#turn_shadow)" opacity="0.86" />
              <Rect x={curve("2.48:1180:ease_out, 2.82:520:ease_in_out, 3.18:-260:ease_in_out")} y="-40" width="120" height="2000" fill="url(#turn_highlight)" opacity="0.34" blend="screen" />
            </Group>
            <Group id="page_turn_02" opacity={curve("0:0:linear, 5.48:0:linear, 5.64:0.92:ease_out, 6.18:0:ease_in, 19:0:linear")}>
              <Rect x={curve("5.48:1120:ease_out, 5.82:430:ease_in_out, 6.18:-360:ease_in_out")} y="-40" width="380" height="2000" fill="url(#turn_shadow)" opacity="0.86" />
              <Rect x={curve("5.48:1180:ease_out, 5.82:520:ease_in_out, 6.18:-260:ease_in_out")} y="-40" width="120" height="2000" fill="url(#turn_highlight)" opacity="0.34" blend="screen" />
            </Group>
            <Group id="page_turn_03" opacity={curve("0:0:linear, 8.48:0:linear, 8.64:0.92:ease_out, 9.18:0:ease_in, 19:0:linear")}>
              <Rect x={curve("8.48:1120:ease_out, 8.82:430:ease_in_out, 9.18:-360:ease_in_out")} y="-40" width="380" height="2000" fill="url(#turn_shadow)" opacity="0.86" />
              <Rect x={curve("8.48:1180:ease_out, 8.82:520:ease_in_out, 9.18:-260:ease_in_out")} y="-40" width="120" height="2000" fill="url(#turn_highlight)" opacity="0.34" blend="screen" />
            </Group>
            <Group id="page_turn_04" opacity={curve("0:0:linear, 11.48:0:linear, 11.64:0.92:ease_out, 12.18:0:ease_in, 19:0:linear")}>
              <Rect x={curve("11.48:1120:ease_out, 11.82:430:ease_in_out, 12.18:-360:ease_in_out")} y="-40" width="380" height="2000" fill="url(#turn_shadow)" opacity="0.86" />
              <Rect x={curve("11.48:1180:ease_out, 11.82:520:ease_in_out, 12.18:-260:ease_in_out")} y="-40" width="120" height="2000" fill="url(#turn_highlight)" opacity="0.34" blend="screen" />
            </Group>
            <Group id="page_turn_05" opacity={curve("0:0:linear, 14.48:0:linear, 14.64:0.92:ease_out, 15.18:0:ease_in, 19:0:linear")}>
              <Rect x={curve("14.48:1120:ease_out, 14.82:430:ease_in_out, 15.18:-360:ease_in_out")} y="-40" width="380" height="2000" fill="url(#turn_shadow)" opacity="0.86" />
              <Rect x={curve("14.48:1180:ease_out, 14.82:520:ease_in_out, 15.18:-260:ease_in_out")} y="-40" width="120" height="2000" fill="url(#turn_highlight)" opacity="0.34" blend="screen" />
            </Group>

            <Rect x="0" y="0" width="1080" height="1920" color="#63E6FF" opacity="0.020 + 0.014*(0.5 + 0.5*sin($time.sec*13.0))" blend="screen" />
            <Rect x="0" y="0" width="1080" height="1920" color="#000000" opacity="0.10" />
          </Layer>
        </Sequence>
      </Track>
    </Timeline>
  </Scene>

  <Process id="anica_cyber_book_bloom">
    <Tex id="cyber_book_src" fmt="rgba16f" from="scene:anica_cyber_book_portrait_19s" />
    <Tex id="cyber_book_out" fmt="rgba16f" size={[1080,1920]} />
    <Pass id="cyber_book_post_bloom" kind="compute" effect="bloom"
          in={["cyber_book_src"]} out={["cyber_book_out"]}
          params={{ threshold: "0.18", intensity: "2.45", sigma: "22.0" }} />
  </Process>

  <Present from="anica_cyber_book_bloom" />
</Graph>
