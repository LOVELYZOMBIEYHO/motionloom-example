<Graph fps={30} duration="5s" size={[1280,720]} renderSize={[1280,720]}>
  <Background color="#F7FAFC" />

  <Skeleton id="five_finger_hand_fk_v1">
    <Bone id="root" x="0" y="0" />
    <Bone id="wrist" parent="root" x="0" y="0" />
    <Bone id="palm" parent="wrist" x="0" y="0" />

    <Bone id="thumb_1" parent="palm" x="-42" y="24" />
    <Bone id="thumb_2" parent="thumb_1" x="-46" y="-22" />
    <Bone id="thumb_3" parent="thumb_2" x="-34" y="-14" />

    <Bone id="index_1" parent="palm" x="-24" y="-50" />
    <Bone id="index_2" parent="index_1" x="0" y="-56" />
    <Bone id="index_3" parent="index_2" x="0" y="-42" />

    <Bone id="middle_1" parent="palm" x="0" y="-58" />
    <Bone id="middle_2" parent="middle_1" x="0" y="-64" />
    <Bone id="middle_3" parent="middle_2" x="0" y="-48" />

    <Bone id="ring_1" parent="palm" x="24" y="-50" />
    <Bone id="ring_2" parent="ring_1" x="0" y="-56" />
    <Bone id="ring_3" parent="ring_2" x="0" y="-40" />

    <Bone id="pinky_1" parent="palm" x="44" y="-38" />
    <Bone id="pinky_2" parent="pinky_1" x="0" y="-44" />
    <Bone id="pinky_3" parent="pinky_2" x="0" y="-32" />
  </Skeleton>

